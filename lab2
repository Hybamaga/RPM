using System;
using System.Collections.Generic;
using System.Linq;

namespace StoreDemo
{
    // Базовый класс Товар
    public class Product
    {
        public string Name { get; set; }
        public decimal Price { get; set; }
        public int Quantity { get; set; }
        
        public Product(string name, decimal price, int quantity)
        {
            Name = name;
            Price = price;
            Quantity = quantity;
        }
        
        public virtual string GetInfo()
        {
            return $"Товар: {Name}, Цена: {Price} руб., В наличии: {Quantity}";
        }
    }
    
    // Класс-наследник Продукты питания
    public class FoodProduct : Product
    {
        public string ExpiryDate { get; set; }
        
        public FoodProduct(string name, decimal price, int quantity, string expiryDate)
            : base(name, price, quantity)
        {
            ExpiryDate = expiryDate;
        }
        
        public override string GetInfo()
        {
            return base.GetInfo() + $", Срок годности: {ExpiryDate}";
        }
    }
    
    // Класс-наследник Электроника
    public class ElectronicProduct : Product
    {
        public string Brand { get; set; }
        
        public ElectronicProduct(string name, decimal price, int quantity, string brand)
            : base(name, price, quantity)
        {
            Brand = brand;
        }
        
        public override string GetInfo()
        {
            return base.GetInfo() + $", Бренд: {Brand}";
        }
    }
    
    // Класс Корзина
    public class ShoppingCart
    {
        public string CustomerName { get; set; }
        private List<Product> Items { get; set; }
        
        public ShoppingCart(string customerName)
        {
            CustomerName = customerName;
            Items = new List<Product>();
        }
        
        public void AddItem(Product product, int quantity)
        {
            if (product.Quantity >= quantity)
            {
                Items.Add(product);
                product.Quantity -= quantity;
                Console.WriteLine($"{product.Name} добавлен в корзину");
            }
        }
        
        public decimal CalculateTotal()
        {
            return Items.Sum(p => p.Price);
        }
    }
    
    // Класс Магазин
    public class Store
    {
        public string Name { get; set; }
        private List<Product> Products { get; set; }
        
        public Store(string name)
        {
            Name = name;
            Products = new List<Product>();
        }
        
        public void AddProduct(Product product)
        {
            Products.Add(product);
        }
        
        public Product FindProduct(string name)
        {
            return Products.FirstOrDefault(p => p.Name.Contains(name));
        }
    }
    
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("МАГАЗИН\n");
            
            // Создаем магазин
            var store = new Store("Вкусный Мир");
            
            // Создаем товары
            var milk = new FoodProduct("Молоко", 80m, 50, "2024-12-31");
            var laptop = new ElectronicProduct("Ноутбук", 50000m, 10, "HP");
            
            // Добавляем в магазин
            store.AddProduct(milk);
            store.AddProduct(laptop);
            
            // Покупка
            var cart = new ShoppingCart("Иван");
            cart.AddItem(store.FindProduct("Молоко"), 2);
            cart.AddItem(store.FindProduct("Ноутбук"), 1);
            
            Console.WriteLine($"\nИтого: {cart.CalculateTotal()} руб.");
            
            // Информация о товарах
            Console.WriteLine($"\n{milk.GetInfo()}");
            Console.WriteLine(laptop.GetInfo());
            
            Console.ReadLine();
        }
    }
}
